#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "fileutils"
require "json"
require "net/http"
require "tempfile"
require "tmpdir"
require "uri"

module CodexPlusPlusUpdater
  API_URL = "https://api.github.com/repos/BigPizzaV3/CodexPlusPlus/releases/latest"
  CASK_PATH = File.expand_path("../Casks/codexplusplus.rb", __dir__)
  USER_AGENT = "zanderzhng-homebrew-tap-updater"

  class UpdateError < StandardError; end

  module_function

  def release_from(json)
    data = JSON.parse(json)
    raise UpdateError, "latest GitHub release is not stable" if data["draft"] || data["prerelease"]

    tag = data.fetch("tag_name")
    match = tag.match(/\Av(\d+\.\d+\.\d+)\z/)
    raise UpdateError, "unexpected release tag: #{tag.inspect}" unless match

    version = match[1]
    assets = data.fetch("assets")
    urls = {
      arm: required_asset(assets, "CodexPlusPlus-#{version}-macos-arm64.dmg"),
      intel: required_asset(assets, "CodexPlusPlus-#{version}-macos-x64.dmg"),
    }

    { version: version, assets: urls }
  rescue JSON::ParserError, KeyError, TypeError => e
    raise UpdateError, "invalid latest-release response: #{e.message}"
  end

  def required_asset(assets, name)
    matches = assets.select { |asset| asset["name"] == name }
    raise UpdateError, "release must contain exactly one #{name}" unless matches.length == 1

    matches.first.fetch("browser_download_url")
  end

  def render(cask, release, checksums)
    rendered = replace_once(
      cask,
      /^[ \t]*version ".*"$/,
      %(  version "#{release.fetch(:version)}"),
      "version",
    )
    replace_once(
      rendered,
      /^[ \t]*sha256 arm:[ \t]*".*",\n[ \t]*intel:[ \t]*".*"$/,
      %(  sha256 arm:   "#{checksums.fetch(:arm)}",\n         intel: "#{checksums.fetch(:intel)}"),
      "architecture checksums",
    )
  end

  def replace_once(content, pattern, replacement, label)
    matches = content.scan(pattern)
    raise UpdateError, "expected exactly one #{label} block in cask" unless matches.length == 1

    content.sub(pattern, replacement)
  end

  def fetch(url, redirects: 5)
    raise UpdateError, "too many redirects for #{url}" if redirects.negative?

    uri = URI(url)
    request = Net::HTTP::Get.new(uri, request_headers(uri, accept: "application/vnd.github+json"))
    response = Net::HTTP.start(uri.hostname, uri.port, use_ssl: uri.scheme == "https") do |http|
      http.request(request)
    end

    case response
    when Net::HTTPSuccess
      response.body
    when Net::HTTPRedirection
      fetch(redirect_url(url, response), redirects: redirects - 1)
    else
      raise UpdateError, "GET #{url} failed: #{response.code} #{response.message}"
    end
  rescue SocketError, SystemCallError, Timeout::Error => e
    raise UpdateError, "GET #{url} failed: #{e.message}"
  end

  def download(url, destination, redirects: 5)
    raise UpdateError, "too many redirects for #{url}" if redirects.negative?

    uri = URI(url)
    request = Net::HTTP::Get.new(uri, request_headers(uri))
    Net::HTTP.start(uri.hostname, uri.port, use_ssl: uri.scheme == "https") do |http|
      http.request(request) do |response|
        case response
        when Net::HTTPSuccess
          File.open(destination, "wb") { |file| response.read_body { |chunk| file.write(chunk) } }
        when Net::HTTPRedirection
          return download(redirect_url(url, response), destination, redirects: redirects - 1)
        else
          raise UpdateError, "GET #{url} failed: #{response.code} #{response.message}"
        end
      end
    end
  rescue SocketError, SystemCallError, Timeout::Error => e
    raise UpdateError, "GET #{url} failed: #{e.message}"
  end

  def redirect_url(url, response)
    location = response["location"]
    raise UpdateError, "redirect from #{url} has no location" unless location

    URI.join(url, location).to_s
  end

  def request_headers(uri, token: github_token, accept: nil)
    headers = { "User-Agent" => USER_AGENT }
    headers["Accept"] = accept if accept
    headers["Authorization"] = "Bearer #{token}" if token && uri.hostname == "api.github.com"
    headers
  end

  def github_token
    ENV["GITHUB_TOKEN"] || ENV["HOMEBREW_GITHUB_API_TOKEN"]
  end

  def atomic_write(path, content)
    Tempfile.create([File.basename(path), ".tmp"], File.dirname(path)) do |file|
      file.write(content)
      file.flush
      file.fsync
      FileUtils.chmod(File.stat(path).mode, file.path)
      File.rename(file.path, path)
    end
  end

  def run(check: false, api_url: ENV.fetch("CODEXPLUSPLUS_API_URL", API_URL), cask_path: CASK_PATH)
    release = release_from(fetch(api_url))
    cask = File.read(cask_path)
    current_version = cask[/^[ \t]*version "([^"]+)"$/, 1]
    raise UpdateError, "could not read current cask version" unless current_version

    if current_version == release.fetch(:version)
      puts "codexplusplus is already at #{current_version}"
      return false
    end

    if check
      puts "codexplusplus update available: #{current_version} -> #{release.fetch(:version)}"
      return true
    end

    checksums = Dir.mktmpdir("codexplusplus-update-") do |directory|
      release.fetch(:assets).to_h do |architecture, url|
        destination = File.join(directory, File.basename(URI(url).path))
        download(url, destination)
        [architecture, Digest::SHA256.file(destination).hexdigest]
      end
    end

    atomic_write(cask_path, render(cask, release, checksums))
    puts "updated codexplusplus: #{current_version} -> #{release.fetch(:version)}"
    true
  end
end

if __FILE__ == $PROGRAM_NAME
  begin
    unless (ARGV - ["--check"]).empty? && ARGV.count("--check") <= 1
      warn "Usage: #{File.basename($PROGRAM_NAME)} [--check]"
      exit 2
    end

    CodexPlusPlusUpdater.run(check: ARGV.include?("--check"))
  rescue CodexPlusPlusUpdater::UpdateError => e
    warn "update failed: #{e.message}"
    exit 1
  end
end
